def f(s, m):
    if s>=666: return m%2==0
    if m==0: return 0
    h= (f(s+3, m-1), f(s*3, m-1), f(s+s*s, m-1))
    return any(h) if (m-1)%2==0 else all(h)

print(min(*(s for s in range (1, 666) if f(s, 2)))) #5
print(*(s for s in range (1, 666) if f(s, 3) and (not(f(s, 1))))) #8 22
print(*(s for s in range(1, 666) if f(s, 4) and (not(f(s,2))))) #19
