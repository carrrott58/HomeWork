from sys import *
setrecursionlimit(20000)

def f(s1,s2,m):
    if s1+s2<=69: return m%2==0
    if m==0: return 0
    h = (f(s1-5, s2+2, m-1), f(s1+2, s2-5, m-1), f(s1//2, s2,m-1), f(s1,s2//2, m-1))
    return any(h) if (m-1)%2==0 else all(h)

print(*(s for s in range (200, 50, -1) if f(s, 35, 2))) #70
print(*(s for s in range (200, 50, -1) if not f(s, 35, 1) and f(s, 35, 3))) #71 141
print(*(s for s in range (200, 50, -1) if not f(s, 35, 2) and f(s, 35, 4))) #72

