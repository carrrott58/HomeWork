def f(s1,s2,m):
    if s1+s2>=259: return m%2==0
    if m==0: return 0
    h = (f(s1+1, s2, m-1), f(s1,s2+1,m-1), f(s1*2, s2, m-1), f(s1, s2*2, m-1))
    return any(h) if (m - 1) % 2 ==0 else all(h)

print(*(s for s in range (1, 242) if f(s, 17, 2))) #61
print(*(s for s in range (1, 242) if not f(s, 17, 1) and f(s, 17, 3))) #112 120
print(*(s for s in range (1, 242) if not f(s, 17, 2) and f(s, 17, 4))) #111
