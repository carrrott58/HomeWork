def f(s1, s2, m):
    if s1+s2>=65: return m%2==0
    if m==0: return 0
    h = (f(s1 + 1, s2, m - 1), f(s1, s2 + 1, m - 1), f(s1 * 3, s2, m - 1), f(s1, s2 * 3, m - 1))
    return any(h) if (m-1)%2==0 else all(h)

print(*(s for s in range (1, 58) if f(s, 6, 2))) #7
print(*(s for s in range (1, 58) if f(s, 6, 3) and not(f(s, 6, 1)))) #10 19
print(*(s for s in range (1, 58) if f(s, 6, 4) and not(f(s, 6, 2)))) #18
