def f(s1,s2,m):
    if s1+s2>=79: return m%2==0
    if m==0: return 0
    h = (f(s1+1, s2, m-1), f(s1,s2+1,m-1), f(s1+s2, s2, m-1), f(s1, s2+s1, m-1))
    return any(h) if (m - 1) % 2 ==0 else all(h)

print(*(s for s in range (1, 69) if f(s, 9, 2))) #21
print(*(s for s in range (1, 69) if not f(s, 9, 1) and f(s, 9, 3))) #20 34
print(*(s for s in range (1, 69) if not f(s, 9, 2) and f(s, 9, 4))) #33
